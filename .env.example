# Copy this file to .env and fill in real values. .env is gitignored — never
# commit real secrets. See config.py for how each of these is consumed.

# Required. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Flask's debug mode / interactive debugger. Must be 0 (or unset) in
# production — leaving it on exposes a remote code execution console.
FLASK_DEBUG=0

# Port the dev server (python app.py) listens on.
PORT=3000

# Leave unset to use SQLite (default, zero setup, fine for this journal's
# scale). Set to a Postgres URL to switch — see DEPLOYMENT.md "Filesystem &
# data" for the full migration steps. e.g.:
# DATABASE_URL=postgresql://user:password@host:5432/jtead
DATABASE_URL=

# Send the session/remember cookies only over HTTPS. Only set this to 1 once
# the app is actually served over HTTPS — otherwise the browser will refuse
# to send the cookie at all, and login won't stick.
SESSION_COOKIE_SECURE=0

# Backend Flask-Limiter uses to track rate limits. The default (memory://)
# only works correctly with a single worker process; point this at a shared
# backend (e.g. redis://localhost:6379) once running with more than one
# gunicorn worker.
RATELIMIT_STORAGE_URI=memory://

# --- Password reset / verification email (mailer.py) ---
# Leave SMTP_HOST unset to use the dev fallback: reset/verification links
# are logged instead of emailed. Any standard SMTP relay works here (Gmail
# app passwords, an institutional SMTP server, SendGrid/Mailgun's SMTP
# endpoints, etc).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=1
MAIL_FROM=no-reply@jtead.local
